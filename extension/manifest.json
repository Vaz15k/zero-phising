{
  "manifest_version": 3,
  "name": "Zero Phishing",
  "version": "1.0.0",
  "description": "Verifica automaticamente URLs contra APIs de phishing e malware.",

  "permissions": [
    "tabs",
    "notifications",
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "https://safebrowsing.googleapis.com/*",
    "https://www.virustotal.com/*",
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Zero Phishing"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
