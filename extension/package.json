{
  "name": "zero-phishing",
  "description": "Extensão de segurança contra phishing, malware e controle de acesso.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@wxt-dev/module-react": "^1.2.2",
    "eslint": "^9.x",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^6.0.3",
    "wxt": "^0.20.27"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "spawn-sync@1.0.15": true
  }
}
